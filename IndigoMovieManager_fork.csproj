<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Platform Condition="'$(Platform)' == ''">x64</Platform>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Title>IndigoMovieManager_fork</Title>
    <AssemblyName>IndigoMovieManager_fork</AssemblyName>
    <Product>IndigoMovieManager_fork</Product>
    <Company>IndigoMovieManager_fork</Company>
    <RootNamespace>IndigoMovieManager</RootNamespace>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <FileVersion>1.0.0.6</FileVersion>
    <AssemblyVersion></AssemblyVersion>
    <!-- 一時検証で作られた生成物が本体へ混入しないよう、既定includeの入口で除外する -->
    <DefaultItemExcludes>$(DefaultItemExcludes);artifacts\**\*;bench_worktrees\**\*;tools\SwfAirThumbnailProbe\**\*;obj\**\*;bin\**\*</DefaultItemExcludes>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <Optimize>False</Optimize>
    <DebugType>full</DebugType>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <DebugType>full</DebugType>
    <Optimize>False</Optimize>
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <PropertyGroup>
    <!-- 既定は内包版UsnMftを参照し、必要時のみ外部UsnMftへ切り替える -->
    <UseExternalUsnMft>false</UseExternalUsnMft>
    <ExternalUsnMftProjectPath></ExternalUsnMftProjectPath>
    <!-- SQLitePCLRaw の distro 固有 RID 警告を避けるため、既存互換の RID グラフを使う -->
    <UseRidGraph>true</UseRidGraph>
  </PropertyGroup>

  <PropertyGroup Condition="'$(UseExternalUsnMft)'=='true'">
    <DefineConstants>$(DefineConstants);USE_EXTERNAL_USNMFT</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="errorBig.jpg" />
    <None Remove="errorSmall.jpg" />
    <None Remove="errorGrid.jpg" />
    <None Remove="errorList.jpg" />
    <!-- ベンチ用資産は本体アプリのビルド対象から除外する -->
    <Compile Remove="Thumbnail\Bench\**\*.cs;Thumbnail\BenchOutput\**\*.cs;Thumbnail\ChatHistoryBackup_*\**\*.cs;Thumbnail\Test\**\*.cs;Thumbnail\QueueObj.cs;Thumbnail\TabInfo.cs;Thumbnail\ThumbInfo.cs;Thumbnail\Tools.cs;Thumbnail\ThumbnailCreationService.cs;Thumbnail\ThumbnailCreationFacade.cs;Thumbnail\ThumbnailCreationRuntime.cs;Thumbnail\ThumbnailCreationRuntimeFactory.cs;Thumbnail\ThumbnailCreationRuntimeProvider.cs;Thumbnail\ThumbnailCreationServiceFactory.cs;Thumbnail\ThumbnailCreationOrchestrationCoordinator.cs;Thumbnail\ThumbnailCsvUtility.cs;Thumbnail\ThumbnailEngineCatalog.cs;Thumbnail\ThumbnailEngineExecutionCoordinator.cs;Thumbnail\ThumbnailExecutionFlowCoordinator.cs;Thumbnail\ThumbnailEnvConfig.cs;Thumbnail\ThumbnailFailureFinalizer.cs;Thumbnail\ThumbnailImageUtility.cs;Thumbnail\ThumbnailJobContextFactory.cs;Thumbnail\ThumbnailJobMaterialBuilder.cs;Thumbnail\ThumbnailMovieMetaCache.cs;Thumbnail\ThumbnailOutputLockManager.cs;Thumbnail\ThumbnailParallelController.cs;Thumbnail\ThumbnailPathResolver.cs;Thumbnail\ThumbnailPlaceholderUtility.cs;Thumbnail\ThumbnailPreflightChecker.cs;Thumbnail\ThumbnailProcessLogFinalizer.cs;Thumbnail\ThumbnailRepairExecutionCoordinator.cs;Thumbnail\ThumbnailRepairRerunCoordinator.cs;Thumbnail\ThumbnailRepairWorkflowCoordinator.cs;Thumbnail\ThumbnailResultCompletionCoordinator.cs;Thumbnail\ThumbnailResultFactory.cs;Thumbnail\ThumbnailResultFinalizer.cs;Thumbnail\ThumbnailShellMetadataUtility.cs;Thumbnail\Engines\**\*.cs;Thumbnail\Decoders\**\*.cs;Thumbnail\Swf\**\*.cs;Thumbnail\QueueDb\**\*.cs;Thumbnail\QueuePipeline\**\*.cs;Thumbnail\ThumbnailQueueProcessor.cs;Thumbnail\ThumbnailProgressRuntime.cs;Tests\**\*.cs;src\**\*.cs;tools\SwfAirThumbnailProbe\**\*.cs;tools\SwfAirThumbnailProbe\obj\**\*.cs;bench_worktrees\**\*.cs;obj\**\*.cs;bin\**\*.cs;obj2\**\*.cs;obj_lock_backup\**\*.cs" />
    <Page Remove="src\**\*.xaml;bench_worktrees\**\*.xaml;obj\**\*.xaml;bin\**\*.xaml;obj2\**\*.xaml;obj_lock_backup\**\*.xaml" />
    <ApplicationDefinition Remove="src\**\App.xaml;bench_worktrees\**\App.xaml;obj\**\App.xaml;bin\**\App.xaml;obj2\**\App.xaml;obj_lock_backup\**\App.xaml" />
    <None Remove="Thumbnail\Bench\**\*;Thumbnail\BenchOutput\**\*;Thumbnail\ChatHistoryBackup_*\**\*;Tests\**\*;tools\SwfAirThumbnailProbe\**\*;bench_worktrees\**\*;obj\**\*;bin\**\*;obj2\**\*;obj_lock_backup\**\*" />
    <Content Remove="Thumbnail\Bench\**\*;Thumbnail\BenchOutput\**\*;Thumbnail\ChatHistoryBackup_*\**\*;Tests\**\*;tools\SwfAirThumbnailProbe\**\*;bench_worktrees\**\*;obj\**\*;bin\**\*;obj2\**\*;obj_lock_backup\**\*" />
    <EmbeddedResource Remove="Thumbnail\Bench\**\*;Thumbnail\BenchOutput\**\*;Thumbnail\ChatHistoryBackup_*\**\*;Tests\**\*;tools\SwfAirThumbnailProbe\**\*;bench_worktrees\**\*;obj\**\*;bin\**\*;obj2\**\*;obj_lock_backup\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dirkster.AvalonDock" Version="4.72.1" />
    <PackageReference Include="Dirkster.AvalonDock.Themes.VS2013" Version="4.72.1" />
    <PackageReference Include="EverythingSearchClient" Version="0.9.0.148" />
    <PackageReference Include="FFMediaToolkit" Version="4.8.1" />
    <PackageReference Include="FFmpeg.AutoGen" Version="7.1.1" />
    <PackageReference Include="MaterialDesignColors" Version="5.3.0" />
    <PackageReference Include="MaterialDesignThemes" Version="5.3.0" />
    <PackageReference Include="Microsoft.Xaml.Behaviors.Wpf" Version="1.1.135" />
    <PackageReference Include="Notification.Wpf" Version="8.0.0" />
    <PackageReference Include="OpenCvSharp4.Extensions" Version="4.11.0.20250507" />
    <PackageReference Include="OpenCvSharp4.Windows" Version="4.11.0.20250507" />
    <PackageReference Include="System.Data.SqlClient" Version="4.9.0" />
    <PackageReference Include="System.Data.SQLite" Version="2.0.2" />
    <PackageReference Include="System.Drawing.Common" Version="10.0.2" />
    <PackageReference Include="System.IO.Hashing" Version="10.0.3" />
    <PackageReference Include="System.ObjectModel" Version="4.3.0" />
    <PackageReference Include="VirtualizingWrapPanel" Version="2.3.2" />
    <!-- SQLite ネイティブバイナリのバンドルを追加 -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.0.6" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="src\IndigoMovieManager.Thumbnail.Engine\IndigoMovieManager.Thumbnail.Engine.csproj" />
    <ProjectReference Include="src\IndigoMovieManager.Thumbnail.Queue\IndigoMovieManager.Thumbnail.Queue.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseExternalUsnMft)'=='true'">
    <ProjectReference Include="$(ExternalUsnMftProjectPath)" Condition="Exists('$(ExternalUsnMftProjectPath)')" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseExternalUsnMft)'!='true'">
    <ProjectReference Include="src\IndigoMovieManager.FileIndex.UsnMft\IndigoMovieManager.FileIndex.UsnMft.csproj" />
  </ItemGroup>

  <Target
    Name="ValidateExternalUsnMftReference"
    BeforeTargets="ResolveReferences"
    Condition="'$(UseExternalUsnMft)'=='true' and !Exists('$(ExternalUsnMftProjectPath)')"
  >
    <Error Text="UseExternalUsnMft=true ですが外部参照が見つかりません: $(ExternalUsnMftProjectPath)" />
  </Target>

  <Target
    Name="ForceIncludeGeneratedWpfCode"
    BeforeTargets="CoreCompile"
    Condition="'$(UseWPF)'=='true' and $([System.String]::Copy('$(MSBuildProjectFile)').Contains('wpftmp')) != 'True'"
  >
    <!-- SDK 側で g.cs が Compile に載らない環境があるため、生成済みの WPF コードだけを直前で補完する -->
    <ItemGroup>
      <Compile
        Include="$(IntermediateOutputPath)**\*.g.cs"
        Exclude="
          @(Compile);
          $(IntermediateOutputPath)**\*.GlobalUsings.g.cs;
          $(IntermediateOutputPath)**\*.AssemblyInfo.cs;
          $(IntermediateOutputPath)src\**\*.g.cs;
          $(IntermediateOutputPath)**\*wpftmp*.g.cs;
          $(IntermediateOutputPath)bench_worktrees\**\*.g.cs"
      />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <Content Include="Images\errorBig.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Images\errorSmall.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Images\errorGrid.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Images\errorList.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Settings.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
    <Compile Update="RenameFile.xaml.cs">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Images\noFileBig.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Images\noFileGrid.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Images\nofileList.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Images\noFileSmall.jpg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

  <ItemGroup Condition="Exists('tools\ffmpeg\ffmpeg.exe')">
    <!-- 同梱用: tools/ffmpeg/ffmpeg.exe がある場合だけ出力先へコピーする -->
    <None Update="tools\ffmpeg\ffmpeg.exe">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="Exists('tools\ffmpeg\LICENSE-ffmpeg-lgpl.txt')">
    <!-- LGPL同梱用: 配布時に参照できるようライセンス文面も出力へ載せる -->
    <None Update="tools\ffmpeg\LICENSE-ffmpeg-lgpl.txt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="Exists('tools\\ffmpeg-shared')">
    <!-- FFMediaToolkit用: shared DLL一式を出力先へ同梱する -->
    <None Update="tools\\ffmpeg-shared\\*.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="Exists('tools\\sinku\\Sinku.dll')">
    <!-- sinkuhadouken連携用: Sinku.dll を出力先へ同梱する -->
    <None Update="tools\\sinku\\Sinku.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup Condition="Exists('tools\\sinku')">
    <!-- sinkuhadouken連携用: ini群を出力先へ同梱する -->
    <None Update="tools\\sinku\\*.ini">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Target Name="BuildThumbnailWorker" AfterTargets="Build">
    <!-- 外部Workerを本体出力へ同梱し、UIから直接起動できるようにする -->
    <PropertyGroup>
      <ThumbnailWorkerSourceDir>$(MSBuildThisFileDirectory)src\IndigoMovieManager.Thumbnail.Worker\bin\$(Platform)\$(Configuration)\net8.0-windows\</ThumbnailWorkerSourceDir>
      <ThumbnailWorkerTargetDir>$(OutDir)thumbnail-worker\</ThumbnailWorkerTargetDir>
      <ThumbnailWorkerRuntimeSourceDir>$(OutDir)</ThumbnailWorkerRuntimeSourceDir>
      <!-- no-restore 相当では既存 assets を使ってビルドだけ進める -->
      <ThumbnailWorkerBuildTargets Condition="'$(Restore)'=='false'">Build</ThumbnailWorkerBuildTargets>
      <ThumbnailWorkerBuildTargets Condition="'$(Restore)'!='false'">Restore;Build</ThumbnailWorkerBuildTargets>
      <!-- 旧実装の残骸で自己再帰コピーが起きるため、thumbnail-worker配下は除外する -->
      <ThumbnailWorkerNestedOutputDir>$(ThumbnailWorkerSourceDir)thumbnail-worker\</ThumbnailWorkerNestedOutputDir>
      <ThumbnailWorkerNestedTargetDir>$(ThumbnailWorkerTargetDir)thumbnail-worker\</ThumbnailWorkerNestedTargetDir>
    </PropertyGroup>
    <Exec
      Command="pwsh -NoLogo -Command &quot;$target=[IO.Path]::GetFullPath('$(ThumbnailWorkerTargetDir)'); Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'IndigoMovieManager.Thumbnail.Worker.exe' } | ForEach-Object { $cmd=$_.CommandLine; if([string]::IsNullOrWhiteSpace($cmd)){ return }; if($cmd.IndexOf($target,[System.StringComparison]::OrdinalIgnoreCase) -lt 0){ return }; if($null -eq (Get-Process -Id $_.ParentProcessId -ErrorAction SilentlyContinue)){ Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue } }&quot;"
      IgnoreExitCode="true"
    />
    <MSBuild
      Projects="src\IndigoMovieManager.Thumbnail.Worker\IndigoMovieManager.Thumbnail.Worker.csproj"
      Targets="$(ThumbnailWorkerBuildTargets)"
      Properties="Configuration=$(Configuration);Platform=$(Platform);Restore=$(Restore)"
    />
    <RemoveDir Directories="$(ThumbnailWorkerNestedOutputDir)" Condition="Exists('$(ThumbnailWorkerNestedOutputDir)')" />
    <RemoveDir Directories="$(ThumbnailWorkerNestedTargetDir)" Condition="Exists('$(ThumbnailWorkerNestedTargetDir)')" />
    <ItemGroup>
      <ThumbnailWorkerOutputFiles
        Include="$(ThumbnailWorkerSourceDir)**\*"
        Exclude="$(ThumbnailWorkerNestedOutputDir)**\*"
      />
      <!-- Worker単体起動でもQueueDBへ触れるよう、SQLite系の実行依存を本体出力から補完する -->
      <ThumbnailWorkerRuntimeRootFiles
        Include="
          $(ThumbnailWorkerRuntimeSourceDir)System.Data.SQLite.dll;
          $(ThumbnailWorkerRuntimeSourceDir)SQLitePCLRaw*.dll"
      />
      <ThumbnailWorkerRuntimeNativeFiles
        Include="$(ThumbnailWorkerRuntimeSourceDir)runtimes\**\*"
      />
    </ItemGroup>
    <MakeDir Directories="$(ThumbnailWorkerTargetDir)" />
    <Copy
      SourceFiles="@(ThumbnailWorkerOutputFiles)"
      DestinationFiles="@(ThumbnailWorkerOutputFiles->'$(ThumbnailWorkerTargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
    />
    <Copy
      SourceFiles="@(ThumbnailWorkerRuntimeRootFiles)"
      DestinationFiles="@(ThumbnailWorkerRuntimeRootFiles->'$(ThumbnailWorkerTargetDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
    />
    <Copy
      SourceFiles="@(ThumbnailWorkerRuntimeNativeFiles)"
      DestinationFiles="@(ThumbnailWorkerRuntimeNativeFiles->'$(ThumbnailWorkerTargetDir)runtimes\%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
    />
  </Target>

  <Target Name="BuildThumbnailDropTool" AfterTargets="Build">
    <!-- ドロップ専用の簡易ツールを同梱し、DB無しの単発サムネ生成を別導線で提供する -->
    <PropertyGroup>
      <ThumbnailDropToolSourceDir>$(MSBuildThisFileDirectory)artifacts\thumbnail-drop-tool-stage\$(Platform)\$(Configuration)\</ThumbnailDropToolSourceDir>
      <ThumbnailDropToolTargetDir>$(OutDir)thumbnail-drop-tool\</ThumbnailDropToolTargetDir>
      <ThumbnailDropToolBuildTargets Condition="'$(Restore)'=='false'">Build</ThumbnailDropToolBuildTargets>
      <ThumbnailDropToolBuildTargets Condition="'$(Restore)'!='false'">Restore;Build</ThumbnailDropToolBuildTargets>
      <ThumbnailDropToolNestedOutputDir>$(ThumbnailDropToolSourceDir)thumbnail-drop-tool\</ThumbnailDropToolNestedOutputDir>
      <ThumbnailDropToolNestedTargetDir>$(ThumbnailDropToolTargetDir)thumbnail-drop-tool\</ThumbnailDropToolNestedTargetDir>
    </PropertyGroup>
    <Exec
      Command="pwsh -NoLogo -Command &quot;$target=[IO.Path]::GetFullPath('$(ThumbnailDropToolTargetDir)'); Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'IndigoMovieManager.Thumbnail.DropTool.exe' } | ForEach-Object { $cmd=$_.CommandLine; if([string]::IsNullOrWhiteSpace($cmd)){ return }; if($cmd.IndexOf($target,[System.StringComparison]::OrdinalIgnoreCase) -lt 0){ return }; if($null -eq (Get-Process -Id $_.ParentProcessId -ErrorAction SilentlyContinue)){ Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue } }&quot;"
      IgnoreExitCode="true"
    />
    <MSBuild
      Projects="src\IndigoMovieManager.Thumbnail.DropTool\IndigoMovieManager.Thumbnail.DropTool.csproj"
      Targets="$(ThumbnailDropToolBuildTargets)"
      Properties="Configuration=$(Configuration);Platform=$(Platform);OutDir=$(ThumbnailDropToolSourceDir);Restore=$(Restore)"
    />
    <RemoveDir
      Directories="$(ThumbnailDropToolNestedOutputDir)"
      Condition="Exists('$(ThumbnailDropToolNestedOutputDir)')"
    />
    <RemoveDir
      Directories="$(ThumbnailDropToolNestedTargetDir)"
      Condition="Exists('$(ThumbnailDropToolNestedTargetDir)')"
    />
    <ItemGroup>
      <ThumbnailDropToolOutputFiles
        Include="$(ThumbnailDropToolSourceDir)**\*"
        Exclude="$(ThumbnailDropToolNestedOutputDir)**\*"
      />
    </ItemGroup>
    <MakeDir Directories="$(ThumbnailDropToolTargetDir)" />
    <Copy
      SourceFiles="@(ThumbnailDropToolOutputFiles)"
      DestinationFiles="@(ThumbnailDropToolOutputFiles->'$(ThumbnailDropToolTargetDir)%(RecursiveDir)%(Filename)%(Extension)')"
      SkipUnchangedFiles="true"
    />
  </Target>

  <Target Name="BuildAdminTelemetryService" AfterTargets="Build">
    <!-- 管理者サービスを本体出力へ同梱し、通常権限UIから昇格起動できるようにする -->
