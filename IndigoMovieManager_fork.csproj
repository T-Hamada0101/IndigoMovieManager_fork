  <Target Name="BuildThumbnailProgressViewer" AfterTargets="Build">
    <!-- 進捗Viewerを別窓配布し、本体タブは軽量表示へ寄せる -->
    <PropertyGroup>
      <ThumbnailProgressViewerSourceDir>$(MSBuildThisFileDirectory)artifacts\thumbnail-progress-viewer-stage\$(Platform)\$(Configuration)\</ThumbnailProgressViewerSourceDir>
      <ThumbnailProgressViewerTargetDir>$(OutDir)thumbnail-progress-viewer\</ThumbnailProgressViewerTargetDir>
