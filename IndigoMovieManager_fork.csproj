      <ThumbnailProgressViewerNestedTargetDir>$(ThumbnailProgressViewerTargetDir)thumbnail-progress-viewer\</ThumbnailProgressViewerNestedTargetDir>
    </PropertyGroup>
    <Exec
      Command="pwsh -NoLogo -Command &quot;$target=[IO.Path]::GetFullPath('$(ThumbnailProgressViewerTargetDir)'); Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'IndigoMovieManager.Thumbnail.ProgressViewer.exe' } | ForEach-Object { $cmd=$_.CommandLine; if([string]::IsNullOrWhiteSpace($cmd)){ return }; if($cmd.IndexOf($target,[System.StringComparison]::OrdinalIgnoreCase) -lt 0){ return }; if($null -eq (Get-Process -Id $_.ParentProcessId -ErrorAction SilentlyContinue)){ Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue } }&quot;"
