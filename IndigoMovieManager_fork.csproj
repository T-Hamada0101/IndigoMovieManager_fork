  <Target Name="BuildThumbnailCoordinator" AfterTargets="Build">
    <!-- 外側の運転席制御口を同梱し、本体から Coordinator を直接起動できるようにする -->
    <PropertyGroup>
      <ThumbnailCoordinatorSourceDir>$(MSBuildThisFileDirectory)artifacts\thumbnail-coordinator-stage\$(Platform)\$(Configuration)\</ThumbnailCoordinatorSourceDir>
      <ThumbnailCoordinatorTargetDir>$(OutDir)thumbnail-coordinator\</ThumbnailCoordinatorTargetDir>
      <ThumbnailCoordinatorBuildTargets Condition="'$(Restore)'=='false'">Build</ThumbnailCoordinatorBuildTargets>
      <ThumbnailCoordinatorBuildTargets Condition="'$(Restore)'!='false'">Restore;Build</ThumbnailCoordinatorBuildTargets>
      <ThumbnailCoordinatorNestedOutputDir>$(ThumbnailCoordinatorSourceDir)thumbnail-coordinator\</ThumbnailCoordinatorNestedOutputDir>
      <ThumbnailCoordinatorNestedTargetDir>$(ThumbnailCoordinatorTargetDir)thumbnail-coordinator\</ThumbnailCoordinatorNestedTargetDir>
      <ThumbnailCoordinatorRuntimeSourceDir>$(OutDir)</ThumbnailCoordinatorRuntimeSourceDir>
    </PropertyGroup>
    <Exec
      Command="pwsh -NoLogo -Command &quot;$target=[IO.Path]::GetFullPath('$(ThumbnailCoordinatorTargetDir)'); Get-CimInstance Win32_Process | Where-Object { $_.Name -eq 'IndigoMovieManager.Thumbnail.Coordinator.exe' } | ForEach-Object { $cmd=$_.CommandLine; if([string]::IsNullOrWhiteSpace($cmd)){ return }; if($cmd.IndexOf($target,[System.StringComparison]::OrdinalIgnoreCase) -lt 0){ return }; if($null -eq (Get-Process -Id $_.ParentProcessId -ErrorAction SilentlyContinue)){ Stop-Process -Id $_.ProcessId -Force -ErrorAction SilentlyContinue } }&quot;"
      IgnoreExitCode="true"
    />
    <MSBuild
      Projects="src\IndigoMovieManager.Thumbnail.Coordinator\IndigoMovieManager.Thumbnail.Coordinator.csproj"
      Targets="$(ThumbnailCoordinatorBuildTargets)"
      Properties="Configuration=$(Configuration);Platform=$(Platform);OutDir=$(ThumbnailCoordinatorSourceDir);Restore=$(Restore)"
    />
    <RemoveDir
      Directories="$(ThumbnailCoordinatorNestedOutputDir)"
      Condition="Exists('$(ThumbnailCoordinatorNestedOutputDir)')"
    />
    <RemoveDir
      Directories="$(ThumbnailCoordinatorNestedTargetDir)"
      Condition="Exists('$(ThumbnailCoordinatorNestedTargetDir)')"
    />
    <ItemGroup>
      <ThumbnailCoordinatorOutputFiles
        Include="$(ThumbnailCoordinatorSourceDir)**\*"
        Exclude="$(ThumbnailCoordinatorNestedOutputDir)**\*"
      />
      <!-- Coordinator 単体起動でも QueueDB を開けるよう、SQLite 系 native/runtime を本体出力から補完する -->
      <ThumbnailCoordinatorRuntimeRootFiles
        Include="
          $(ThumbnailCoordinatorRuntimeSourceDir)System.Data.SQLite.dll;
