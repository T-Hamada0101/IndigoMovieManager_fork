<Window
  x:Class="IndigoMovieManager.Thumbnail.DropTool.DropToolWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="サムネイル Worker"
  Width="820"
  Height="760"
  MinWidth="720"
  MinHeight="620"
  WindowStartupLocation="CenterScreen"
  ShowActivated="True"
  Background="#FFF7F3EA"
>
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,18">
      <TextBlock
        FontSize="30"
        FontWeight="Bold"
        Foreground="#FF2E2419"
        Text="サムネイル Worker"
      />
      <TextBlock
        Margin="0,8,0,0"
        FontSize="14"
        Foreground="#FF5C4E3B"
        Text="この画面自体が Worker.exe です。開始を押すと、この画面内でサムネイル処理を実行します。"
        TextWrapping="Wrap"
      />
    </StackPanel>

    <Border
      Grid.Row="1"
      Margin="0,0,0,16"
      Padding="18"
      Background="#FFFFFCF6"
      BorderBrush="#FFCCB88C"
      BorderThickness="2"
      CornerRadius="18"
      AllowDrop="True"
      DragOver="InputDropArea_DragOver"
      Drop="InputDropArea_Drop"
    >
      <StackPanel>
        <TextBlock
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#FF2E2419"
          Text="1. 変換したい画像またはフォルダ"
        />
        <TextBlock
          Margin="0,6,0,12"
          FontSize="13"
          Foreground="#FF6E624F"
          Text="ファイルまたはフォルダをそのままドロップできます。フォルダは再帰で探索します。"
          TextWrapping="Wrap"
        />
        <Border
          Padding="12"
          Background="#FFF7EFE0"
          BorderBrush="#FFE2D3B2"
          BorderThickness="1"
          CornerRadius="12"
        >
          <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
            <TextBlock
              x:Name="InputSummaryTextBlock"
              FontFamily="Consolas"
              FontSize="13"
              Foreground="#FF3A3027"
              Text="未選択"
              TextWrapping="Wrap"
            />
          </ScrollViewer>
        </Border>
      </StackPanel>
    </Border>

    <Border
      Grid.Row="2"
      Margin="0,0,0,16"
      Padding="18"
      Background="#FFFFFCF6"
      BorderBrush="#FFCCB88C"
      BorderThickness="2"
      CornerRadius="18"
      AllowDrop="True"
      DragOver="OutputDropArea_DragOver"
      Drop="OutputDropArea_Drop"
    >
      <StackPanel>
        <TextBlock
          FontSize="18"
          FontWeight="SemiBold"
          Foreground="#FF2E2419"
          Text="2. 出力フォルダ (Thumb / Thum)"
        />
        <TextBlock
          Margin="0,6,0,12"
          FontSize="13"
          Foreground="#FF6E624F"
          Text="出力先フォルダを1つだけドロップします。配下にサムネイル用のサイズ別フォルダを作成します。"
          TextWrapping="Wrap"
        />
        <Border
          Padding="12"
          Background="#FFF7EFE0"
          BorderBrush="#FFE2D3B2"
          BorderThickness="1"
          CornerRadius="12"
        >
          <TextBlock
            x:Name="OutputSummaryTextBlock"
            FontFamily="Consolas"
            FontSize="13"
            Foreground="#FF3A3027"
            Text="未選択"
            TextWrapping="Wrap"
          />
        </Border>
      </StackPanel>
    </Border>

    <Border
      Grid.Row="3"
      Margin="0,0,0,16"
      Padding="18"
      Background="#FFFFFCF6"
      BorderBrush="#FFCCB88C"
      BorderThickness="2"
      CornerRadius="18"
    >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="24" />
          <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock
            FontSize="18"
            FontWeight="SemiBold"
            Foreground="#FF2E2419"
            Text="3. サムネサイズ"
          />
          <TextBlock
            Margin="0,6,0,12"
            FontSize="13"
            Foreground="#FF6E624F"
            Text="既存アプリで使っている種類から選択します。"
            TextWrapping="Wrap"
          />
          <ComboBox
            x:Name="ThumbnailSizeComboBox"
            Height="38"
            Padding="8,4"
            Background="#FFF7EFE0"
            BorderBrush="#FFE2D3B2"
            BorderThickness="1"
            DisplayMemberPath="DisplayText"
            FontSize="14"
            Foreground="#FF3A3027"
          />
        </StackPanel>

        <StackPanel Grid.Column="2">
          <TextBlock
            FontSize="18"
            FontWeight="SemiBold"
            Foreground="#FF2E2419"
            Text="4. 並列数"
          />
          <TextBlock
            Margin="0,6,0,12"
            FontSize="13"
            Foreground="#FF6E624F"
            Text="同時に処理するファイル数を選びます。"
            TextWrapping="Wrap"
          />
          <ComboBox
            x:Name="ParallelismComboBox"
            Height="38"
            Padding="8,4"
            Background="#FFF7EFE0"
            BorderBrush="#FFE2D3B2"
            BorderThickness="1"
            DisplayMemberPath="DisplayText"
            FontSize="14"
            Foreground="#FF3A3027"
          />
        </StackPanel>
      </Grid>
    </Border>

    <DockPanel Grid.Row="4" Margin="0,0,0,16" LastChildFill="False">
      <TextBlock
        x:Name="StatusTextBlock"
        VerticalAlignment="Center"
        FontSize="14"
        Foreground="#FF5C4E3B"
        Text="待機中"
      />
      <Button
        x:Name="StartButton"
        DockPanel.Dock="Right"
        Width="160"
        Height="42"
        Padding="20,8"
        Background="#FF9A6B29"
        BorderBrush="#FF9A6B29"
        Click="StartButton_Click"
        Content="開始"
        FontSize="16"
        FontWeight="SemiBold"
        Foreground="White"
      />
    </DockPanel>

    <Border
      Grid.Row="5"
      Padding="16"
      Background="#FF1E1B18"
      CornerRadius="18"
    >
      <DockPanel LastChildFill="True">
        <TextBlock
          DockPanel.Dock="Top"
          Margin="0,0,0,10"
          FontSize="16"
          FontWeight="SemiBold"
          Foreground="#FFF6E8CF"
          Text="ログ"
        />
        <TextBox
          x:Name="LogTextBox"
          Background="#FF1E1B18"
          BorderThickness="0"
          FontFamily="Consolas"
          FontSize="13"
          Foreground="#FFF3F0EA"
          IsReadOnly="True"
          TextWrapping="Wrap"
          VerticalScrollBarVisibility="Auto"
          AcceptsReturn="True"
        />
      </DockPanel>
    </Border>
  </Grid>
</Window>
