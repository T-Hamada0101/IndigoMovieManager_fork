<Window
    x:Class="IndigoMovieManager.ThumbnailProgressViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:IndigoMovieManager.Converter"
    Title="サムネイル 運転席"
    Width="1180"
    Height="760"
    MinWidth="900"
    MinHeight="580">
    <Window.Resources>
        <conv:NoLockImageConverter x:Key="noLockImageConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.ColumnSpan="3" Padding="10" Background="#FFF5F7FA" BorderBrush="#FFD5DDE5" BorderThickness="1" CornerRadius="6">
            <DockPanel>
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding HeaderTitle}" />
                    <TextBlock Margin="0,4,0,0" Foreground="#FF44515E" Text="{Binding HeaderStatus}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" VerticalAlignment="Top" Foreground="#FF667788" Text="{Binding UpdatedAtText}" />
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="0">
            <TextBlock Margin="0,0,0,6" FontSize="14" FontWeight="Bold" Text="基本情報" />
            <Separator Margin="0,0,0,8" />

            <DockPanel Margin="0,0,0,4">
                <TextBlock Width="150" Text="作成済み / 総キュー" />
                <TextBlock Text="{Binding Progress.CreatedQueueText}" />
            </DockPanel>
            <DockPanel Margin="0,0,0,4">
                <TextBlock Width="150" Text="稼働中 / 設定上限 / 論理コア" />
                <TextBlock Text="{Binding Progress.ThreadText}" />
            </DockPanel>
            <DockPanel Margin="0,0,0,8">
                <TextBlock Width="150" Text="現在制御" />
                <TextBlock Text="{Binding Progress.ControlStateText}" />
            </DockPanel>

            <TextBlock Margin="0,0,0,6" FontSize="14" FontWeight="Bold" Text="運転席" />
            <Separator Margin="0,0,0,8" />

            <DockPanel Margin="0,0,0,4">
                <TextBlock Width="150" Text="Coordinator 状態" />
                <TextBlock x:Name="CoordinatorStateText" Text="取得待ち" />
            </DockPanel>
            <DockPanel Margin="0,0,0,4">
                <TextBlock Width="150" Text="希望 / 実効" />
                <TextBlock x:Name="CoordinatorParallelismText" Text="-" />
            </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="fast / slow" />
                  <TextBlock x:Name="CoordinatorSlotText" Text="-" />
              </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="queued / running" />
                  <TextBlock x:Name="CoordinatorQueueText" Text="-" />
              </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="需要 n/s/r" />
                  <TextBlock x:Name="CoordinatorDemandText" Text="-" />
              </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="重み n/s" />
                  <TextBlock x:Name="CoordinatorWeightText" Text="-" />
              </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="slow 範囲" />
                  <TextBlock x:Name="CoordinatorSlowRangeText" Text="-" />
              </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="判断分類" />
                  <TextBlock x:Name="CoordinatorDecisionCategoryText" Text="-" FontWeight="Bold" />
              </DockPanel>
              <DockPanel Margin="0,0,0,4">
                  <TextBlock Width="150" Text="判断要約" />
                  <TextBlock
                    x:Name="CoordinatorDecisionSummaryText"
                    Text="初期待ち"
                    TextTrimming="CharacterEllipsis" />
              </DockPanel>
              <DockPanel Margin="0,0,0,8">
                  <TextBlock Width="150" Text="理由" />
                  <TextBlock
                    x:Name="CoordinatorReasonText"
                    Text="初期待ち"
                    TextTrimming="CharacterEllipsis" />
            </DockPanel>

            <DockPanel Margin="0,0,0,4">
                <TextBlock Width="150" VerticalAlignment="Center" Text="希望並列数" />
                <TextBox x:Name="RequestedParallelismTextBox" Width="80" />
            </DockPanel>
            <DockPanel Margin="0,0,0,4">
                <TextBlock Width="150" VerticalAlignment="Center" Text="巨大動画閾値(GB)" />
                <TextBox x:Name="LargeMovieThresholdTextBox" Width="80" />
            </DockPanel>
            <DockPanel Margin="0,0,0,8">
                <TextBlock Width="150" VerticalAlignment="Center" Text="運転モード" />
                <ComboBox x:Name="OperationModeComboBox" Width="140" SelectedIndex="0">
                    <ComboBoxItem Tag="normal-first" Content="通常優先" />
                    <ComboBoxItem Tag="power-save" Content="省電力" />
                    <ComboBoxItem Tag="recovery-first" Content="回復優先" />
                </ComboBox>
            </DockPanel>
            <CheckBox
                x:Name="GpuDecodeEnabledCheckBox"
                Margin="0,0,0,8"
                Content="GPUデコードを使う" />
            <DockPanel Margin="0,0,0,8">
                <TextBlock Width="150" VerticalAlignment="Center" Text="一時調整" />
                <StackPanel Orientation="Horizontal">
                    <Button Width="42" Click="TemporaryDeltaMinusButton_Click" Content="-1" />
                    <TextBlock
                        x:Name="TemporaryDeltaText"
                        Width="40"
                        Margin="8,0"
                        VerticalAlignment="Center"
                        TextAlignment="Center"
                        Text="0" />
                    <Button Width="42" Click="TemporaryDeltaResetButton_Click" Content="0" />
                    <Button Width="42" Margin="8,0,0,0" Click="TemporaryDeltaPlusButton_Click" Content="+1" />
                </StackPanel>
            </DockPanel>
            <Button
                x:Name="ApplyCoordinatorCommandButton"
                Margin="0,0,0,6"
                Click="ApplyCoordinatorCommandButton_Click"
                Content="運転席設定を反映" />
            <TextBlock
                x:Name="CoordinatorCommandStatusText"
                Margin="0,0,0,8"
                Foreground="#FF586573"
                Text="command未送信"
                TextWrapping="Wrap" />

            <TextBlock Margin="0,0,0,6" FontSize="14" FontWeight="Bold" Text="判断履歴" />
            <Separator Margin="0,0,0,8" />
            <Border Height="160" Margin="0,0,0,8" Padding="6" BorderBrush="#FFD5DDE5" BorderThickness="1" CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CoordinatorDecisionHistory}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,6" Padding="6" Background="#FFF8FAFC" BorderBrush="#FFE0E7EF" BorderThickness="1" CornerRadius="4">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,2">
                                            <TextBlock FontWeight="Bold" Foreground="{Binding AccentBrush}" Text="{Binding CategoryText}" />
                                            <TextBlock DockPanel.Dock="Right" Foreground="#FF667788" Text="{Binding UpdatedAtText}" />
                                        </DockPanel>
                                        <TextBlock Foreground="#FF44515E" Text="{Binding SummaryText}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock Margin="0,0,0,6" FontSize="14" FontWeight="Bold" Text="投入ログ" />
            <Separator Margin="0,0,0,8" />
            <Border Height="140" Padding="6" BorderBrush="#FFD5DDE5" BorderThickness="1" CornerRadius="4">
                <ItemsControl ItemsSource="{Binding Progress.QueueLogs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,4" Text="{Binding}" TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Grid.Column="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Progress.WorkerPanels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="230" Margin="4" Padding="6" BorderBrush="#664A4A4A" BorderThickness="1" CornerRadius="4">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#00FFFFFF" />
                                    <Setter Property="Opacity" Value="1.0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive, Mode=OneWay}" Value="False">
                                            <Setter Property="Background" Value="#22A0A0A0" />
                                            <Setter Property="Opacity" Value="0.70" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <DockPanel Margin="0,0,0,2">
                                    <TextBlock FontSize="12" FontWeight="Bold" Text="{Binding WorkerLabel, Mode=OneWay}" />
                                    <Border DockPanel.Dock="Right" Margin="6,0,0,0" Padding="6,1" Background="#33000000" CornerRadius="3">
                                        <TextBlock FontSize="10" Text="{Binding StatusText, Mode=OneWay}" />
                                    </Border>
                                </DockPanel>
                                <TextBlock Margin="0,2,0,6" Text="{Binding MovieName, Mode=OneWay}" TextTrimming="CharacterEllipsis" ToolTip="{Binding MovieName, Mode=OneWay}" />
                                <Border BorderBrush="#44333333" BorderThickness="1">
                                    <Image Height="72" Stretch="Uniform" Source="{Binding PreviewImagePath, Converter={StaticResource noLockImageConverter}, ConverterParameter=72}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
