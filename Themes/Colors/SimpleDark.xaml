    <SolidColorBrush x:Key="SearchBoxForeground" Color="#FFF1F1F1" />
    <SolidColorBrush x:Key="SortComboBackground" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="SortComboForeground" Color="#FFF1F1F1" />

    <SolidColorBrush x:Key="MainHeaderBackground" Color="#FF2B2B2B" />
