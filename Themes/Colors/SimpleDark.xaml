    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock">

    <!-- SimpleDark は OS ダークに近い中立灰色で、文字と境界だけをはっきりさせる。 -->
    <avalonDock:Vs2013DarkTheme x:Key="AvalonDockTheme" />

    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#FF202020" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#FF333333" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#FF4A4A4A" />
    <SolidColorBrush x:Key="AppTextBrush" Color="#FFF1F1F1" />
    <SolidColorBrush x:Key="AppTextSubtleBrush" Color="#FFB8B8B8" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#FF8AB4F8" />
    <SolidColorBrush x:Key="AppAccentForegroundBrush" Color="#FF111318" />

    <SolidColorBrush x:Key="MaterialDesignPaper" Color="#FF202020" />
    <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#FF2B2B2B" />
    <SolidColorBrush x:Key="MaterialDesignDivider" Color="#FF4A4A4A" />
    <SolidColorBrush x:Key="MaterialDesignBody" Color="#FFF1F1F1" />
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="#FFB8B8B8" />
    <SolidColorBrush x:Key="MaterialDesignBodySecondary" Color="#FFB8B8B8" />
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#FF8AB4F8" />
    <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#FF111318" />

    <SolidColorBrush x:Key="TagBorderBackground" Color="#FF284A2F" />
