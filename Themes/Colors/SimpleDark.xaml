    <SolidColorBrush x:Key="SettingsForegroundBrush" Color="#FFF1F1F1" />

    <SolidColorBrush x:Key="PlayerControllerBackground" Color="#FF111318" />
    <SolidColorBrush x:Key="BadgeIdleBackground" Color="#FF333333" />
    <SolidColorBrush x:Key="BadgeThreadActiveBackground" Color="#FF284A2F" />
