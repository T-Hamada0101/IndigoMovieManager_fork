<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock">

    <!-- SimpleLight は OS 標準に近い白、薄い灰色、標準文字色だけを基準にする。 -->
    <avalonDock:Vs2013LightTheme x:Key="AvalonDockTheme" />

    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#FFD9D9D9" />
    <SolidColorBrush x:Key="AppTextBrush" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="AppTextSubtleBrush" Color="#FF666666" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#FF0067C0" />
    <SolidColorBrush x:Key="AppAccentForegroundBrush" Color="#FFFFFFFF" />

    <!-- WPF標準部品が既定テンプレートを使っても、背景と文字が同系統で揃うようにする。 -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#FFD9D9D9" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#FFB8B8B8" />
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#FF777777" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF0067C0" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="MaterialDesignPaper" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MaterialDesignDivider" Color="#FFD9D9D9" />
    <SolidColorBrush x:Key="MaterialDesignBody" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="#FF666666" />
    <SolidColorBrush x:Key="MaterialDesignBodySecondary" Color="#FF666666" />
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#FF0067C0" />
    <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="TagBorderBackground" Color="#FFEAF6EA" />
    <SolidColorBrush x:Key="UpperTabBackground" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="UpperTabBackgroundBrush" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="ThumbImageBackground" Color="#FFEDEDED" />
    <SolidColorBrush x:Key="ThumbImageBackgroundBrush" Color="#FFEDEDED" />
    <SolidColorBrush x:Key="HeaderForeground" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="SearchBoxBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SearchBoxForeground" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="SortComboBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="SortComboForeground" Color="#FF1F1F1F" />

    <SolidColorBrush x:Key="MainHeaderBackground" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="MainHeaderBackgroundBrush" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="MainHeaderForegroundBrush" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="MainHeaderInputForegroundBrush" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="MainHeaderSearchBoxBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MainHeaderSortComboBackground" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="NavigationDrawerBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="NavigationDrawerForegroundBrush" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="LeftDrawerForegroundBrush" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="UpperTabPanelForegroundBrush" Color="#FF1F1F1F" />
    <SolidColorBrush x:Key="GridTabTitleForegroundBrush" Color="#FF666666" />
    <SolidColorBrush x:Key="SettingsForegroundBrush" Color="#FF1F1F1F" />

    <SolidColorBrush x:Key="PlayerControllerBackground" Color="#FF15171A" />
    <SolidColorBrush x:Key="BadgeIdleBackground" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="BadgeThreadActiveBackground" Color="#FFEAF6EA" />
    <SolidColorBrush x:Key="BadgeThreadActiveBorder" Color="#FF9DCC9D" />
    <SolidColorBrush x:Key="BadgeRescueActiveBackground" Color="#FFFCEAEA" />
    <SolidColorBrush x:Key="BadgeRescueActiveBorder" Color="#FFE4A6A6" />
    <Color x:Key="PlayerShadowColor">#FFB07A1A</Color>
</ResourceDictionary>
