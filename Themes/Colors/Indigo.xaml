<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock">

    <!-- 従来の Original 相当の色を、Indigo プロファイルの正本として残す。 -->
    <avalonDock:Vs2013LightTheme x:Key="AvalonDockTheme" />

    <SolidColorBrush x:Key="AppWindowBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#FFF7F7F7" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#FFD6D6D6" />
    <SolidColorBrush x:Key="AppTextBrush" Color="#DD000000" />
    <SolidColorBrush x:Key="AppTextSubtleBrush" Color="#99000000" />
    <SolidColorBrush x:Key="AppAccentBrush" Color="#FF303F9F" />
    <SolidColorBrush x:Key="AppAccentForegroundBrush" Color="#FFFFFFFF" />

    <!-- MaterialDesign を外しても既存参照が解決できるよう、主要 Brush key は自前でも持つ。 -->
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MaterialDesignDivider" Color="#1F000000" />
    <SolidColorBrush x:Key="MaterialDesignBody" Color="#DD000000" />
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="#99000000" />
    <SolidColorBrush x:Key="MaterialDesignBodySecondary" Color="#99000000" />
    <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#FF303F9F" />
    <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#FFFFFFFF" />

    <!-- 旧キーは既存 XAML の互換層として維持し、App 独自キーへ段階移行できる形にする。 -->
    <SolidColorBrush x:Key="TagBorderBackground" Color="LightGreen" />
    <SolidColorBrush x:Key="UpperTabBackground" Color="DarkBlue" />
    <SolidColorBrush x:Key="UpperTabBackgroundBrush" Color="DarkBlue" />
    <SolidColorBrush x:Key="ThumbImageBackground" Color="Black" />
    <SolidColorBrush x:Key="ThumbImageBackgroundBrush" Color="Black" />
    <SolidColorBrush x:Key="HeaderForeground" Color="White" />
    <SolidColorBrush x:Key="SearchBoxBackground" Color="White" />
    <SolidColorBrush x:Key="SearchBoxForeground" Color="Black" />
    <SolidColorBrush x:Key="SortComboBackground" Color="White" />
    <SolidColorBrush x:Key="SortComboForeground" Color="Black" />

    <SolidColorBrush x:Key="MainHeaderBackground" Color="#FF303F9F" />
    <SolidColorBrush x:Key="MainHeaderBackgroundBrush" Color="#FF303F9F" />
    <SolidColorBrush x:Key="MainHeaderForegroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MainHeaderInputForegroundBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="MainHeaderSearchBoxBackground" Color="White" />
    <SolidColorBrush x:Key="MainHeaderSortComboBackground" Color="White" />

    <SolidColorBrush x:Key="NavigationDrawerBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="NavigationDrawerForegroundBrush" Color="#FF303F9F" />
    <SolidColorBrush x:Key="LeftDrawerForegroundBrush" Color="#FF303F9F" />
    <SolidColorBrush x:Key="UpperTabPanelForegroundBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="GridTabTitleForegroundBrush" Color="DarkGray" />
    <SolidColorBrush x:Key="SettingsForegroundBrush" Color="#FF000000" />

    <SolidColorBrush x:Key="PlayerControllerBackground" Color="Black" />
    <SolidColorBrush x:Key="BadgeIdleBackground" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="BadgeThreadActiveBackground" Color="#FFE4F5E3" />
    <SolidColorBrush x:Key="BadgeThreadActiveBorder" Color="#FF9FC99B" />
    <SolidColorBrush x:Key="BadgeRescueActiveBackground" Color="#FFF8E3E3" />
    <SolidColorBrush x:Key="BadgeRescueActiveBorder" Color="#FFD8A3A3" />
    <Color x:Key="PlayerShadowColor">DarkGoldenrod</Color>
</ResourceDictionary>
